# ==============================================
# EXEMPLO DE CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE
# ==============================================
# Copie este arquivo para .env e preencha com os valores reais

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_HOST=postgres-dev
DB_PORT=5433
DB_NAME=geosegbar_dev
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=9090
FRONTEND_URL=http://localhost:3000
BACKUP_BASE_DIR=$HOME/db_backups
BACKUP_KEEP_COUNT=7

# ==============================================
# SECURITY
# ==============================================
JWT_SECRET=your_jwt_secret_key_min_256_bits_here
CLI_PASSWORD=change_me_for_cli_actions
ADMIN_BYPASS_KEY=change_me_for_admin_bypass

# ==============================================
# EMAIL CONFIGURATION
# ==============================================
MAIL_HOST=mail.example.com
MAIL_PORT=465
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=your_email_password_here

# ==============================================
# FILE STORAGE
# ==============================================
FILE_UPLOAD_DIR=/home/wwgeomprod/public_html/storage/app/public
FILE_BASE_URL=/storage/
FILE_PSB_DIR=/home/wwgeomprod/public_html/storage/app/public/psb

# ==============================================
# EXTERNAL API - ANA
# ==============================================
ANA_API_IDENTIFIER=your_ana_identifier
ANA_API_PASSWORD=your_ana_password
ANA_API_AUTH_URL=https://www.ana.gov.br/hidrowebservice/EstacoesTelemetricas/OAUth/v1
ANA_API_TELEMETRY_URL=https://www.ana.gov.br/hidrowebservice/EstacoesTelemetricas/HidroinfoanaSerieTelemetricaAdotada/v1

# ==============================================
# JAVA OPTIONS
# ==============================================
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# ==============================================
# TIMEZONE
# ==============================================
TZ=America/Sao_Paulo

# ==============================================
# REDIS
# ==============================================
REDIS_HOST=redis-prod
REDIS_PORT=6379
REDIS_PASSWORD=

# ==============================================
# RATE LIMITING
# ==============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_CAPACITY=100
RATE_LIMIT_PUBLIC_REFILL_TOKENS=100
RATE_LIMIT_PUBLIC_REFILL_DURATION=1
RATE_LIMIT_AUTH_CAPACITY=200
RATE_LIMIT_AUTH_REFILL_TOKENS=200
RATE_LIMIT_AUTH_REFILL_DURATION=1

# ==============================================
# MONITORING
# ==============================================
GRAFANA_PASSWORD=change_me_grafana_password
PROMETHEUS_RETENTION=30d

# ==============================================
# SYSTEM
# ==============================================
SYSTEM_USER_PASSWORD=change_me_system_password
CLI_PASSWORD=change_me_cli_password